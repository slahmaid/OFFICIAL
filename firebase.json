{
  "firestore": {
    "rules": "firebase/firestore.rules",
    "indexes": "firebase/firestore.indexes.json"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "google-apps-script/**",
      "build-bundles.ps1"
    ],
    "redirects": [
      { "source": "/img/logo.svg", "destination": "/images/logo.svg", "type": 301 },
      { "source": "/img/moka/:file", "destination": "/moka/images/:file", "type": 301 },
      { "source": "/img/saqr/:file", "destination": "/saqr/images/:file", "type": 301 },
      { "source": "/img/projectors/:file", "destination": "/projectors/images/:file", "type": 301 },
      { "source": "/img/:file", "destination": "/moka-pro-max/images/:file", "type": 301 }
    ],
    "rewrites": [
      { "source": "/admin", "destination": "/admin/index.html" },
      { "source": "/admin/**", "destination": "/admin/index.html" }
    ],
    "headers": [
      {
        "source": "/admin/**",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "**/*.@(jpg|jpeg|png|webp|gif|svg|ico)",
        "headers": [{ "key": "Cache-Control", "value": "public,max-age=31536000,immutable" }]
      },
      {
        "source": "**/*.@(css|js)",
        "headers": [{ "key": "Cache-Control", "value": "public,max-age=604800" }]
      }
    ]
  }
}
